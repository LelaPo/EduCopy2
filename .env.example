# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Education API Configuration
# Base URL for the education API (e.g., https://authedu.mosreg.ru)
API_BASE_URL=https://authedu.mosreg.ru

# Bearer token for API authentication
API_BEARER_TOKEN=your_bearer_token_here

# Admin Configuration
# Telegram ID of the bot administrator (numeric value)
# You can get your Telegram ID from @userinfobot
ADMIN_ID=123456789

# Database Configuration
# Path to the SQLite database file
DB_PATH=./data/homework_bot.db

# SOCKS5 Proxy Configuration (Optional)
# Used for connecting to Telegram (not the education API)
# Leave empty or comment out if not using a proxy
# PROXY_HOST=127.0.0.1
# PROXY_PORT=1080
# PROXY_USER=your_proxy_username
# PROXY_PASS=your_proxy_password

# Logging Configuration
# Log level: debug, info, warn, error
LOG_LEVEL=info
